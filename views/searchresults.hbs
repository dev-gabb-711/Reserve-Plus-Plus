<!DOCTYPE html>
<html lang="en">
<head>
  <!--========================= META + TITLE =========================-->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Results</title>

  <!--========================= VENDORS + FONTS =========================-->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

  <!--========================= PAGE STYLES =========================-->
  <link rel="stylesheet" href="/css/searchresults.css">
</head>

<body class="page page--searchresults">
  <!--========================= BACKGROUND LAYER =========================-->
  <div class="app-bg"></div>

  <!--========================= PAGE WRAPPER =========================-->
  <div class="page-wrap">

    <!--========================= SIDEBAR NAV =========================-->
    <aside class="side-nav">
      <div class="side-icons">

        <button class="side-btn" type="button" onclick="goToDashboard()">
          <span class="material-symbols-rounded">home</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/reserve'">
          <span class="material-symbols-rounded">computer</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/it-assist'">
          <span class="material-symbols-rounded">report</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/notifications'">
          <span class="material-symbols-rounded">notifications</span>
        </button>
      </div>

      <div class="side-brand">
        <img src="/img/logo.png" class="brand-logo" alt="Logo">
      </div>
    </aside>

    <!--========================= MAIN CONTENT =========================-->
    <main class="main-area">

      <!--========================= HEADER (TITLE + SEARCH) =========================-->
      <div class="top-row">
        <div>
          <h1 class="page-title">Showing Results</h1>
          <p class="page-subtitle">Find available seats in real time</p>
        </div>

        <div class="search-wrap">
          <div class="search-pill">
            <span class="search-ico">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15z"></path>
              </svg>
            </span>
            <input id="searchInput" type="text" placeholder="Search for labs here..." />
          </div>
        </div>
      </div>

      <!--========================= RESULTS SHELL =========================-->
      <section class="result-shell">

        <!--========================= FILTER CONTROLS =========================-->
        <div class="result-head">
          <button class="filter-btn" id="filterBtn" type="button" title="Filters">
            <span class="material-symbols-rounded">tune</span>
          </button>

          <div class="filter-panel" id="filterPanel" aria-hidden="true">

            <div class="filter-grid">

              <label class="filter-field">
                <span>Building</span>
                <select id="buildingFilter">
                  <option value="">All</option>
                  <option value="G">Gokongwei Hall (G)</option>
                  <option value="A">Br. Andrew Hall (A)</option>
                </select>
              </label>

              <label class="filter-field">
                <span>Room (e.g., 203)</span>
                <input id="roomFilter" type="text" placeholder="203" />
              </label>

              <label class="filter-field">
                <span>Date</span>
                <input id="dateFilter" type="date" />
              </label>

              <label class="filter-field">
                <span>Sort</span>
                <select id="sortFilter">
                  <option value="soonest">Soonest</option>
                  <option value="room">Room</option>
                </select>
              </label>

            </div>

            <div class="filter-actions">
              <button class="btn-soft" id="clearFilters" type="button">Clear</button>
              <button class="btn-soft" id="applyFilters" type="button">Apply</button>
            </div>

          </div>
        </div>

        <!--========================= RESULTS LIST =========================-->
        <div class="result-list" id="resultList"></div>

        <!--========================= EMPTY STATE =========================-->
        <p class="result-empty" id="emptyState" hidden>
          No matching results.
        </p>

      </section>

    </main>
  </div>

  <!--========================= PAGE DATA =========================-->
  <script id="searchResultsData" type="application/json">{{{json searchResults}}}</script>

  <!--========================= SCRIPTS =========================-->
  <script src="/js/searchresults.js"></script>
</body>
</html>