<!DOCTYPE html>
<html lang="en">

<head>
  <!--========================= META + LINKS =========================-->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <!--========================= VENDORS + FONTS =========================-->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0">

  <!--========================= PAGE STYLES =========================-->
  <link rel="stylesheet" href="/css/admindashboard.css">
</head>

<body class="page page--admindashboard">
  <!--========================= BACKGROUND LAYER =========================-->
  <div class="app-bg"></div>

  <!--========================= PAGE WRAPPER =========================-->
  <div class="page-wrap">

    <!--========================= SIDEBAR NAV =========================-->
    <aside class="side-nav">
      <div class="side-icons">
        <button class="side-btn active" type="button" onclick="goToDashboard()">
          <span class="material-symbols-rounded">home</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/reserve'">
          <span class="material-symbols-rounded">computer</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/it-assist-admin'">
          <span class="material-symbols-rounded">report</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='/notifications'">
          <span class="material-symbols-rounded">notifications</span>
        </button>
      </div>

      <div class="side-brand">
        <img src="/img/logo.png" class="brand-logo" alt="Logo">
      </div>
    </aside>

    <!--========================= MAIN CONTENT =========================-->
    <main class="main-area">

      <!--========================= DASHBOARD GRID =========================-->
      <div class="dash-grid">

        <!--========================= HEADER (TITLE + SEARCH) =========================-->
        <header class="dash-head">
          <div class="head-left">
            <div>
              <h1 class="page-title">Hi, {{adminUser.firstName}}</h1>
              <p class="page-subtitle">System overview and assistance reports</p>
            </div>

            <div class="search-wrap">
              <div class="search-pill">
                <span class="search-ico">
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="7"></circle>
                    <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
                  </svg>
                </span>
                <input type="text" id="labSearch" placeholder="Search for labs here...">
              </div>
            </div>
          </div>
        </header>

        <!--========================= CENTER COLUMN =========================-->
        <section class="center-col">

          <!--========================= HERO CAROUSEL =========================-->
          <div class="hero-shell">
            <div class="hero-track" id="heroTrack">
              {{#each dashboardBuildings}}
                <article class="hero-card" data-title="{{title}}">
                  <div class="hero-bg"
                    style="background-image:linear-gradient(110deg, rgba(110,55,185,0.2), rgba(0,0,0,0.2)),url('{{image}}')"></div>

                  <div class="hero-inner">
                    <div class="hero-top">
                      <div class="hero-title">{{title}}</div>

                      <div class="hero-arrows">
                        <button class="hero-arrow hero-prev" type="button" aria-label="Previous">
                          <span class="material-symbols-rounded">chevron_left</span>
                        </button>
                        <button class="hero-arrow hero-next" type="button" aria-label="Next">
                          <span class="material-symbols-rounded">chevron_right</span>
                        </button>
                      </div>
                    </div>

                    <div class="room-scroll">
                      <div class="room-grid">
                        {{#each rooms}}
                          <div class="room-row" data-room="{{name}}">
                            <span class="pill-dot {{#if (eq status 'ok')}}ok{{else}}bad{{/if}}"></span>

                            <div class="room-meta">
                              <div class="room-name">{{name}}</div>
                              <div class="room-sub">
                                {{#if (eq status 'ok')}}
                                  All Good
                                {{else}}
                                  {{count}} Assistance Request{{#unless (eq count 1)}}s{{/unless}}
                                {{/if}}
                              </div>
                            </div>
                          </div>
                        {{/each}}
                      </div>
                    </div>
                  </div>
                </article>
              {{/each}}
            </div>
          </div>

          <!--========================= BOTTOM PANELS =========================-->
          <div class="bottom-grid">

            <!--========================= ANNOUNCEMENT PANEL =========================-->
            <div class="panel post-panel">
              <div class="panel-title">Post an Announcement</div>
              <textarea class="post-box" id="announceText"
                placeholder="Write something for students and staff..."></textarea>

              <div class="post-actions">
                <button class="pill-btn" id="postBtn" type="button">Post</button>
                <button class="pill-btn pill-ghost" id="clearBtn" type="button">Cancel</button>
              </div>
            </div>

            <!--========================= TICKETS CAROUSEL =========================-->
            <div class="ticket-shell">
              <div class="ticket-track" id="ticketTrack">
                {{#each dashboardTickets}}
                  <article class="ticket-card">
                    <div class="ticket-bg"></div>

                    <div class="ticket-content">
                      <div class="ticket-head">
                        <div class="ticket-title">Assistance Ticket {{displayId}}</div>
                        <div class="ticket-sub">{{roomLabel}} • {{seatLabel}}</div>
                      </div>

                      <div class="ticket-divider"></div>

                      <div class="ticket-body">
                        <div class="kv-row"><span>Issue : {{issue}}</span></div>
                        <div class="kv-row"><span>Status : {{status}}</span></div>
                        <div class="kv-row"><span>Priority Level : {{priority}}</span></div>
                      </div>

                      <div class="ticket-foot">
                        <form action="/resolve-ticket/{{_id}}" method="POST">
                          <button class="ticket-btn" type="submit">Resolved</button>
                        </form>
                      </div>
                    </div>
                  </article>
                {{/each}}
              </div>
            </div>

          </div>
        </section>

        <!--========================= RIGHT COLUMN =========================-->
        <aside class="right-col">
          <div class="profile-card">
            <div class="profile-row">
              <div class="seal-wrap">
                <img
                  src="{{adminUser.profilePic}}"
                  class="seal"
                  alt="Seal"
                  onerror="this.onerror=null;this.src='/img/dlsu.png';"
                >
              </div>

              <div class="profile-meta">
                <div class="profile-name">{{adminUser.firstName}} {{adminUser.lastName}}</div>
                <div class="profile-role">{{adminUser.role}}</div>

                <div class="profile-actions">
                  <button class="edit-btn" type="button" onclick="location.href='/profile'">Edit Profile</button>

                  <button class="profile-icon-btn logout" type="button" data-bs-toggle="modal"
                    data-bs-target="#logoutModal" aria-label="Log Out">
                    <span class="material-symbols-rounded">logout</span>
                  </button>
                </div>
              </div>
            </div>

            <div class="notif-title">Notifications</div>
            <div class="notif-mini" id="notifMini">
              {{#each miniNotifications}}
                <div class="mini-item">
                  <img
                    src="{{avatar}}"
                    class="mini-ava"
                    alt="{{name}}"
                    onerror="this.onerror=null;this.src='/img/system_profile.png';"
                  >
                  <div class="mini-text">
                    <div class="mini-name">{{name}}</div>
                    <div class="mini-snippet">{{snippet}}</div>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <!--========================= LOGOUT MODAL =========================-->
  <div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content"
        style="background: #161618; border: 1px solid var(--stroke); border-radius: 20px; color: white;">
        <div class="modal-body" style="padding: 30px; text-align: center;">
          <h5 style="margin-bottom: 15px;">Confirm Logout</h5>
          <p style="opacity: 0.7;">Are you sure you want to log out?</p>

          <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
            <button type="button" class="btn" style="color: white; border: 1px solid var(--stroke);"
              data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn" style="background: #ff3b3b; color: white;"
              onclick="location.href='/login'">Logout</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!--========================= SCRIPTS =========================-->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admindashboard.js"></script>
  <script src="/js/search.js"></script>
</body>

</html>