<!DOCTYPE html>
<html lang="en">
<head>
  <!--========================= META + LINKS =========================-->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile</title>

  <!--========================= VENDORS + FONTS =========================-->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

  <!--========================= PAGE STYLES =========================-->
  <link rel="stylesheet" href="../css/profile.css">
</head>

<body class="page page--profile">
  <!--========================= BACKGROUND LAYER =========================-->
  <div class="app-bg"></div>

  <!--========================= PAGE WRAPPER =========================-->
  <div class="page-wrap">

    <!--========================= SIDEBAR NAV =========================-->
    <aside class="side-nav">
      <div class="side-icons">
        <button class="side-btn" type="button" onclick="goToDashboard()">
          <span class="material-symbols-rounded">home</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='rseat.html'">
          <span class="material-symbols-rounded">computer</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='itassist.html'">
          <span class="material-symbols-rounded">report</span>
        </button>

        <button class="side-btn" type="button" onclick="location.href='notifications.html'">
          <span class="material-symbols-rounded">notifications</span>
        </button>
      </div>

      <div class="side-brand">
        <img src="../img/logo.png" class="brand-logo" alt="Logo">
      </div>
    </aside>

    <!--========================= MAIN CONTENT =========================-->
    <main class="main-area">

      <!--========================= HEADER (TITLE + SEARCH) =========================-->
      <div class="top-row">
        <div>
          <h1 class="page-title">My Profile</h1>
          <p class="page-subtitle">Welcome to your account center</p>
        </div>

        <!------------------Search Bar------------------>
        <div class="search-wrap">
          <div class="search-pill">
            <span class="search-ico">
              <svg viewBox="0 0 24 24" fill="none">
                <circle cx="11" cy="11" r="7"></circle>
                <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
              </svg>
            </span>
            <input type="text" id="labSearch" placeholder="Search for Labs here...">
          </div>
        </div>
      </div>

      <!--========================= PROFILE SHELL =========================-->
      <div class="profile-shell">
        <div class="profile-grid">

          <!--========================= LEFT (AVATAR + ACTIONS) =========================-->
          <div class="profile-left">
            <img id="avatarPreview" class="profile-avatar" src="../img/def_avatar.jpg" alt="Profile">

            <!------------------View Mode Actions------------------>
            <div id="leftViewActions" class="left-actions">
              <button id="deleteBtn" class="btn-outline" type="button">Delete Account</button>
              <button id="editBtn" class="btn-outline" type="button">Edit Profile</button>
            </div>

            <!------------------Edit Mode Actions------------------>
            <div id="leftEditActions" class="left-actions is-hidden">
              <label class="btn-outline file-btn" for="avatarFile">Edit Profile Picture</label>
              <input id="avatarFile" class="file-input" type="file" accept="image/*">
            </div>
          </div>

          <!--========================= RIGHT (VIEW + EDIT MODES) =========================-->
          <div class="profile-right">

            <!------------------Profile View Mode------------------>
            <div id="viewMode" class="mode">
              <div class="p-name" id="viewName">Gabrielle Martinez</div>
              <div class="p-role" id="viewRole">Lab User</div>

              <div class="field">
                <div class="label">User Email</div>
                <div class="value" id="viewEmail">ItzGabbyMartinez@dlsu.edu.ph</div>
              </div>

              <div class="field">
                <div class="label">Password</div>
                <div class="value" id="viewPass">****************</div>
              </div>
            </div>

            <!------------------Profile Edit Mode------------------>
            <form id="editMode" class="mode is-hidden" autocomplete="off">
              <input class="edit-input name" id="nameInput" type="text" value="Gabrielle Martinez">
              <div class="p-role">Lab User</div>

              <div class="field">
                <div class="label">User Email</div>
                <input class="edit-input" id="emailInput" type="email" value="ItzGabbyMartinez@dlsu.edu.ph">
              </div>

              <div class="field">
                <div class="label">Password</div>
                <input class="edit-input" id="passInput" type="password" value="passwordpassword">
              </div>

              <!------------------Edit Actions------------------>
              <div class="edit-actions">
                <button id="saveBtn" class="btn-outline wide" type="button">Save Changes</button>
                <button id="cancelBtn" class="btn-outline wide" type="button">Cancel</button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </main>

  </div>

  <!--========================= SCRIPTS =========================-->
  <script src="../js/profile.js"></script>
  <script src="../js/search.js"></script>
</body>
</html>
